rule "60 fill - add second anti-air answer for air weakness"
salience 56
when
    PlayerInsight(code == "AIR_WEAKNESS")
    $d : DeckCandidate($a : archetype, valid == true)
    eval($d.getCards().size() < 8)
    eval($d.countRole(CardRole.ANTI_AIR) < 2)
    $priorities : java.util.List() from collect(CardPriorityFact(archetype == $a, role == CardRole.ANTI_AIR))
    eval(DeckRulesSupport.hasAvailableForDeck(cards, $priorities, $a, CardRole.ANTI_AIR, 5.0, $d))
then
    CardFact card = DeckRulesSupport.bestAvailableForDeck(cards, $priorities, $a, CardRole.ANTI_AIR, 5.0, $d);
    if (card != null && $d.addCard(card)) {
        $d.addScore(3, "Added additional anti-air coverage because air weakness was detected.");
        update($d);
    }
end

