rule "69 fill - cycle filler for low-elixir decks"
salience 51
when
    $d : DeckCandidate($a : archetype, valid == true)
    eval($d.getCards().size() < 8)
    eval($a == Archetype.CYCLE || $a == Archetype.CONTROL)
    $priorities : java.util.List() from collect(CardPriorityFact(archetype == $a, role == CardRole.CYCLE))
    eval(DeckRulesSupport.hasAvailableForDeck(cards, $priorities, $a, CardRole.CYCLE, 3.0, $d))
then
    CardFact card = DeckRulesSupport.bestAvailableForDeck(cards, $priorities, $a, CardRole.CYCLE, 3.0, $d);
    if (card != null && $d.addCard(card)) {
        $d.addScore(2, "Filled a cheap cycle slot from Drools priorities.");
        update($d);
    }
end
