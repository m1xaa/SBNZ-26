package rules;

import com.cr.back.domain.card.CardRole;
import com.cr.back.domain.deck.Archetype;
import com.cr.back.rules.DeckRulesSupport;
import com.cr.back.rules.facts.ArchetypeScore;
import com.cr.back.rules.facts.CardFact;
import com.cr.back.rules.facts.CardPriorityFact;
import com.cr.back.rules.facts.DeckCandidate;
import com.cr.back.rules.facts.PlayerInsight;
import com.cr.back.rules.facts.SelectedCardFact;

global java.util.Collection cards;

rule "53 form - create candidate from positive archetype and selected core"
salience 60
when
    $selected : SelectedCardFact($a : archetype)
    $s : ArchetypeScore(archetype == $a, score > 0)
    not DeckCandidate(archetype == $a)
then
    DeckCandidate deck = new DeckCandidate($a);
    deck.addScore($s.getScore(), "Candidate created after Drools inferred a viable archetype and core card set.");
    insert(deck);
end

rule "54 form - fallback candidate from positive archetype score"
salience 57
when
    $s : ArchetypeScore(score > 0, $a : archetype)
    not DeckCandidate(archetype == $a)
then
    DeckCandidate deck = new DeckCandidate($a);
    deck.addScore($s.getScore(), "Fallback candidate created from a viable archetype score so Drools can continue filling the deck.");
    insert(deck);
end

rule "55 form - attach selected cards to candidate"
salience 58
when
    $selected : SelectedCardFact($a : archetype, $card : card, $reason : reason)
    $d : DeckCandidate(archetype == $a)
    eval(!$d.contains($card.name()))
    eval($d.getCards().size() < 8)
then
    if ($d.addCard($card)) {
        $d.addScore(2, $reason);
        update($d);
    }
end

rule "56 fill - ensure one win condition"
salience 56
when
    $d : DeckCandidate($a : archetype, valid == true)
    eval($d.getCards().size() < 8)
    eval($d.countRole(CardRole.WIN_CONDITION) == 0)
    $priorities : java.util.List() from collect(CardPriorityFact(archetype == $a, role == CardRole.WIN_CONDITION))
    eval(DeckRulesSupport.hasAvailableForDeck(cards, $priorities, $a, CardRole.WIN_CONDITION, 9.0, $d))
then
    CardFact card = DeckRulesSupport.bestAvailableForDeck(cards, $priorities, $a, CardRole.WIN_CONDITION, 9.0, $d);
    if (card != null && $d.addCard(card)) {
        $d.addScore(4, "Filled the win-condition slot from Drools priorities.");
        update($d);
    }
end

rule "57 fill - cycle/control wants a small spell"
salience 56
when
    $d : DeckCandidate($a : archetype, valid == true)
    eval($d.getCards().size() < 8)
    eval(!$d.hasRole(CardRole.SMALL_SPELL))
    eval($a == Archetype.CYCLE || $a == Archetype.CONTROL || $a == Archetype.BAIT || $a == Archetype.BRIDGE_SPAM || $a == Archetype.SIEGE || $a == Archetype.AIR_COUNTER)
    $priorities : java.util.List() from collect(CardPriorityFact(archetype == $a, role == CardRole.SMALL_SPELL))
    eval(DeckRulesSupport.hasAvailableForDeck(cards, $priorities, $a, CardRole.SMALL_SPELL, 3.0, $d))
then
    CardFact card = DeckRulesSupport.bestAvailableForDeck(cards, $priorities, $a, CardRole.SMALL_SPELL, 3.0, $d);
    if (card != null && $d.addCard(card)) {
        $d.addScore(3, "Filled the small-spell slot from Drools priorities.");
        update($d);
    }
end

