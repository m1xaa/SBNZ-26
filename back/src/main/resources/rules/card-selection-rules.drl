package rules;

import com.cr.back.domain.card.CardRole;
import com.cr.back.domain.deck.Archetype;
import com.cr.back.rules.facts.ArchetypeScore;
import com.cr.back.rules.facts.CardFact;
import com.cr.back.rules.facts.CardPriorityFact;
import com.cr.back.rules.facts.DeckCandidate;
import com.cr.back.rules.facts.DeckRequirementFact;
import com.cr.back.rules.facts.PlayerFact;
import com.cr.back.rules.facts.PlayerInsight;

rule "20a priority - base required role score"
salience 68
when
    $s : ArchetypeScore(score > 0, $a : archetype)
    $r : DeckRequirementFact(archetype == $a, $role : role, $max : maxElixir)
    $card : CardFact(unlocked == true, elixirCost <= $max)
    eval($card.hasRole($role))
    not CardPriorityFact(archetype == $a, role == $role, cardName == $card.name(), reason == "BASE_ROLE")
then
    insert(new CardPriorityFact($a, $role, $card.name(), $card.level() * 10, "BASE_ROLE"));
end

rule "20b priority - preferred archetype likes named core"
salience 68
when
    $player : PlayerFact(preferredArchetype != null, $preferred : preferredArchetype)
    $requirement : DeckRequirementFact(archetype == $preferred, $role : role, $max : maxElixir)
    $card : CardFact(unlocked == true, elixirCost <= $max)
    eval($card.hasRole($role))
    not CardPriorityFact(archetype == $preferred, role == $role, cardName == $card.name(), reason == "PLAYER_PREFERENCE")
then
    insert(new CardPriorityFact($preferred, $role, $card.name(), 8, "PLAYER_PREFERENCE"));
end

rule "20c priority - disliked cards are strongly penalized"
salience 69
when
    $player : PlayerFact()
    $s : ArchetypeScore(score > 0, $a : archetype)
    $r : DeckRequirementFact(archetype == $a, $role : role, $max : maxElixir)
    $card : CardFact(unlocked == true, elixirCost <= $max)
    eval($card.hasRole($role))
    eval($player.dislikedCards().contains($card.name()))
    not CardPriorityFact(archetype == $a, role == $role, cardName == $card.name(), reason == "DISLIKED_CARD")
then
    insert(new CardPriorityFact($a, $role, $card.name(), -1000, "DISLIKED_CARD"));
end

rule "21 priority - cycle win condition prefers cheap pressure"
salience 68
when
    DeckRequirementFact(archetype == Archetype.CYCLE, role == CardRole.WIN_CONDITION, $max : maxElixir)
    $card : CardFact(unlocked == true, elixirCost <= $max)
    eval($card.hasRole(CardRole.WIN_CONDITION) && ($card.hasRole(CardRole.PRESSURE) || $card.hasRole(CardRole.CYCLE)))
    not CardPriorityFact(archetype == Archetype.CYCLE, role == CardRole.WIN_CONDITION, cardName == $card.name(), reason == "CYCLE_WIN_CONDITION")
then
    insert(new CardPriorityFact(Archetype.CYCLE, CardRole.WIN_CONDITION, $card.name(), 35, "CYCLE_WIN_CONDITION"));
end

rule "22 priority - cycle support prefers the cheapest cards"
salience 68
when
    DeckRequirementFact(archetype == Archetype.CYCLE, role == CardRole.CYCLE)
    $card : CardFact(unlocked == true, elixirCost <= 2.5, roles contains CardRole.CYCLE)
    not CardPriorityFact(archetype == Archetype.CYCLE, role == CardRole.CYCLE, cardName == $card.name(), reason == "CYCLE_FILLER")
then
    insert(new CardPriorityFact(Archetype.CYCLE, CardRole.CYCLE, $card.name(), 25, "CYCLE_FILLER"));
end

rule "23 priority - control prefers flexible defense"
salience 68
when
    DeckRequirementFact(archetype == Archetype.CONTROL, $role : role)
    $card : CardFact(unlocked == true)
    eval(
        ($role == CardRole.SINGLE_TARGET_DPS && $card.hasRole(CardRole.SINGLE_TARGET_DPS))
        || ($role == CardRole.BIG_SPELL && $card.hasRole(CardRole.BIG_SPELL))
        || ($role == CardRole.WIN_CONDITION && $card.hasRole(CardRole.WIN_CONDITION))
    )
    not CardPriorityFact(archetype == Archetype.CONTROL, role == $role, cardName == $card.name(), reason == "CONTROL_ROLE")
then
    insert(new CardPriorityFact(Archetype.CONTROL, $role, $card.name(), 18, "CONTROL_ROLE"));
end

rule "24 priority - beatdown prioritizes tanks"
salience 68
when
    DeckRequirementFact(archetype == Archetype.BEATDOWN, role == CardRole.TANK)
    $card : CardFact(unlocked == true, roles contains CardRole.TANK)
    not CardPriorityFact(archetype == Archetype.BEATDOWN, role == CardRole.TANK, cardName == $card.name(), reason == "BEATDOWN_TANK")
then
    insert(new CardPriorityFact(Archetype.BEATDOWN, CardRole.TANK, $card.name(), 30, "BEATDOWN_TANK"));
end

rule "25 priority - golem is signature beatdown tank"
salience 68
when
    $card : CardFact(unlocked == true, name == "Golem")
    not CardPriorityFact(archetype == Archetype.BEATDOWN, role == CardRole.TANK, cardName == "Golem", reason == "GOLEM_CORE")
then
    insert(new CardPriorityFact(Archetype.BEATDOWN, CardRole.TANK, $card.name(), 40, "GOLEM_CORE"));
end

rule "25a priority - night witch is premium beatdown support"
salience 68
when
    $card : CardFact(unlocked == true, name == "Night Witch")
    not CardPriorityFact(archetype == Archetype.BEATDOWN, role == CardRole.SUPPORT, cardName == "Night Witch", reason == "GOLEM_SUPPORT")
then
    insert(new CardPriorityFact(Archetype.BEATDOWN, CardRole.SUPPORT, $card.name(), 25, "GOLEM_SUPPORT"));
end

rule "26 priority - bait favors goblin barrel and princess"
salience 68
when
    $card : CardFact(unlocked == true, name == "Goblin Barrel" || name == "Princess")
    not CardPriorityFact(archetype == Archetype.BAIT, cardName == $card.name(), reason == "BAIT_SIGNATURE")
then
    if ($card.name().equals("Goblin Barrel")) {
        insert(new CardPriorityFact(Archetype.BAIT, CardRole.WIN_CONDITION, $card.name(), 40, "BAIT_SIGNATURE"));
        insert(new CardPriorityFact(Archetype.BAIT, CardRole.PRESSURE, $card.name(), 15, "BAIT_SIGNATURE"));
    } else {
        insert(new CardPriorityFact(Archetype.BAIT, CardRole.SWARM, $card.name(), 20, "BAIT_SIGNATURE"));
        insert(new CardPriorityFact(Archetype.BAIT, CardRole.PRESSURE, $card.name(), 20, "BAIT_SIGNATURE"));
    }
end

rule "27 priority - bait swarm cards"
salience 68
when
    DeckRequirementFact(archetype == Archetype.BAIT, role == CardRole.SWARM)
    $card : CardFact(unlocked == true, roles contains CardRole.SWARM)
    not CardPriorityFact(archetype == Archetype.BAIT, role == CardRole.SWARM, cardName == $card.name(), reason == "BAIT_SWARM")
then
    insert(new CardPriorityFact(Archetype.BAIT, CardRole.SWARM, $card.name(), 22, "BAIT_SWARM"));
end

