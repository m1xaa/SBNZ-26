salience 68
when
    DeckRequirementFact(archetype == Archetype.BRIDGE_SPAM, role == CardRole.PRESSURE)
    $card : CardFact(unlocked == true, roles contains CardRole.PRESSURE)
    not CardPriorityFact(archetype == Archetype.BRIDGE_SPAM, role == CardRole.PRESSURE, cardName == $card.name(), reason == "BRIDGE_PRESSURE")
then
    insert(new CardPriorityFact(Archetype.BRIDGE_SPAM, CardRole.PRESSURE, $card.name(), 25, "BRIDGE_PRESSURE"));
end

rule "29 priority - battle ram is signature bridge spam pressure"
salience 68
when
    $card : CardFact(unlocked == true, name == "Battle Ram")
    not CardPriorityFact(archetype == Archetype.BRIDGE_SPAM, role == CardRole.PRESSURE, cardName == "Battle Ram", reason == "BATTLE_RAM_SIGNATURE")
then
    insert(new CardPriorityFact(Archetype.BRIDGE_SPAM, CardRole.PRESSURE, $card.name(), 35, "BATTLE_RAM_SIGNATURE"));
end

rule "30 priority - siege prefers X-Bow and Mortar"
salience 68
when
    $card : CardFact(unlocked == true, name == "X-Bow" || name == "Mortar")
    not CardPriorityFact(archetype == Archetype.SIEGE, role == CardRole.SIEGE, cardName == $card.name(), reason == "SIEGE_SIGNATURE")
then
    insert(new CardPriorityFact(Archetype.SIEGE, CardRole.SIEGE, $card.name(), 35, "SIEGE_SIGNATURE"));
end

rule "31a priority - air weakness favors anti-air in cycle/control/air-counter"
salience 68
when
    PlayerInsight(code == "AIR_WEAKNESS")
    $card : CardFact(unlocked == true, roles contains CardRole.ANTI_AIR)
    $s : ArchetypeScore(score > 0, $a : archetype)
    eval($a == Archetype.CYCLE || $a == Archetype.CONTROL || $a == Archetype.AIR_COUNTER)
    not CardPriorityFact(archetype == $a, role == CardRole.ANTI_AIR, cardName == $card.name(), reason == "AIR_WEAKNESS_ANTI_AIR")
then
    insert(new CardPriorityFact($a, CardRole.ANTI_AIR, $card.name(), 24, "AIR_WEAKNESS_ANTI_AIR"));
end

rule "31b priority - firecracker musketeer baby dragon answer air losses best"
salience 68
when
    PlayerInsight(code == "AIR_WEAKNESS")
    $card : CardFact(unlocked == true, name == "Firecracker" || name == "Musketeer" || name == "Baby Dragon")
    $s : ArchetypeScore(score > 0, $a : archetype)
    not CardPriorityFact(archetype == $a, role == CardRole.ANTI_AIR, cardName == $card.name(), reason == "AIR_SIGNATURE")
then
    insert(new CardPriorityFact($a, CardRole.ANTI_AIR, $card.name(), 20, "AIR_SIGNATURE"));
    insert(new CardPriorityFact($a, CardRole.AIR_SUPPORT_COUNTER, $card.name(), 14, "AIR_SIGNATURE"));
end

rule "31c priority - hog package is strong cycle core"
salience 68
when
    $card : CardFact(
        unlocked == true,
        name == "Hog Rider"
        || name == "Earthquake"
        || name == "Cannon"
        || name == "Firecracker"
        || name == "Ice Spirit"
        || name == "Skeletons"
        || name == "The Log"
    )
    not CardPriorityFact(archetype == Archetype.CYCLE, cardName == $card.name(), reason == "HOG_CYCLE_CORE")
then
    if ($card.name().equals("Hog Rider")) {
        insert(new CardPriorityFact(Archetype.CYCLE, CardRole.WIN_CONDITION, $card.name(), 45, "HOG_CYCLE_CORE"));
    } else if ($card.name().equals("Earthquake") || $card.name().equals("The Log")) {
        insert(new CardPriorityFact(Archetype.CYCLE, CardRole.SMALL_SPELL, $card.name(), 18, "HOG_CYCLE_CORE"));
    } else if ($card.name().equals("Cannon")) {
        insert(new CardPriorityFact(Archetype.CYCLE, CardRole.BUILDING, $card.name(), 20, "HOG_CYCLE_CORE"));
    } else if ($card.name().equals("Firecracker")) {
        insert(new CardPriorityFact(Archetype.CYCLE, CardRole.ANTI_AIR, $card.name(), 18, "HOG_CYCLE_CORE"));
        insert(new CardPriorityFact(Archetype.CYCLE, CardRole.SUPPORT, $card.name(), 14, "HOG_CYCLE_CORE"));
    } else {
        insert(new CardPriorityFact(Archetype.CYCLE, CardRole.CYCLE, $card.name(), 15, "HOG_CYCLE_CORE"));
    }
end

rule "35 card choice - high-level win condition anchors cycle"
salience 35
when
    $d : DeckCandidate(valid == true)
    eval(!$d.hasAppliedRule("35"))
    eval($d.countRole(CardRole.WIN_CONDITION) == 1)
then
    $d.markRule("35");
    $d.addScore(18, "A high-level win condition anchors the selected archetype.");
    update($d);
end

rule "36 card choice - defensive building selected"
salience 35
when
    $d : DeckCandidate(valid == true)
    eval(!$d.hasAppliedRule("36"))
    eval($d.hasRole(CardRole.BUILDING))
then
    $d.markRule("36");
    $d.addScore(8, "A defensive building is available and fits the deck structure.");
    update($d);
end

rule "37 card choice - strong anti-air support selected"
salience 35
when
    PlayerInsight(code == "AIR_WEAKNESS")
    $d : DeckCandidate(valid == true)
    eval(!$d.hasAppliedRule("37"))
    eval($d.contains("Firecracker") || $d.contains("Musketeer") || $d.contains("Baby Dragon"))
then
    $d.markRule("37");
    $d.addScore(12, "High-level anti-air support was prioritized because of the air weakness.");
    update($d);
end

rule "38 card choice - compatible small spell selected"
salience 35
when
    $d : DeckCandidate(valid == true)
    eval(!$d.hasAppliedRule("38"))
    eval($d.hasRole(CardRole.SMALL_SPELL))
then
    $d.markRule("38");
    $d.addScore(8, "A small spell is included for cheap answers and cycle consistency.");
    update($d);
end

rule "39 card choice - cheap reliable support selected"
salience 35
when
    $d : DeckCandidate(valid == true)
    eval(!$d.hasAppliedRule("39"))
    eval($d.countRole(CardRole.CYCLE) >= 2)
then
    $d.markRule("39");
    $d.addScore(7, "Cheap cycle cards fill support slots without raising average elixir.");
    update($d);
end

rule "40 card choice - synergy with win condition"
salience 35
when
    $d : DeckCandidate(valid == true)
    eval(!$d.hasAppliedRule("40"))
    eval(($d.contains("Hog Rider") && $d.contains("Earthquake")) || ($d.contains("Golem") && $d.contains("Night Witch")))
then
    $d.markRule("40");
    $d.addScore(12, "Selected support has strong synergy with the main win condition.");
    update($d);
end
