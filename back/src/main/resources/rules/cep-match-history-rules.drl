package rules;

import com.cr.back.domain.deck.Archetype;
import com.cr.back.domain.match.MatchEventType;
import com.cr.back.domain.match.MatchOutcome;
import com.cr.back.rules.facts.MatchEventFact;
import com.cr.back.rules.facts.MatchFact;
import com.cr.back.rules.facts.OvercommitSequenceFact;
import com.cr.back.rules.facts.PlayerInsight;

rule "08 cep - air weakness from recent losses"
salience 100
when
    not PlayerInsight(code == "AIR_WEAKNESS")
    Number(intValue >= 6) from accumulate(
        MatchFact(outcome == MatchOutcome.LOSS, opponentArchetype == Archetype.AIR_PRESSURE) over window:length(10),
        count(1)
    )
then
    insert(new PlayerInsight("AIR_WEAKNESS", "At least 6 recent losses were against air-heavy archetypes."));
end

rule "09 cep - repeated overcommit sequence in one lost match"
salience 100
when
    $match : MatchFact($matchId : id, outcome == MatchOutcome.LOSS)
    $commit : MatchEventFact(matchId == $matchId, type == MatchEventType.LARGE_ELIXIR_COMMIT, $eventTime : eventTimestamp)
    MatchEventFact(
        matchId == $matchId,
        type in (MatchEventType.TOWER_LOST, MatchEventType.CONTROL_LOST, MatchEventType.HUGE_DAMAGE_TAKEN),
        this after[0s, 45s] $commit
    )
    not OvercommitSequenceFact(matchId == $matchId)
then
    insert(new OvercommitSequenceFact($matchId, $eventTime, "Large elixir commit was followed by major defensive collapse in the same losing match."));
end

rule "10 cep - repeated elixir overcommit across recent losses"
salience 95
when
    not PlayerInsight(code == "OVERCOMMIT")
    Number(intValue >= 2) from accumulate(
        OvercommitSequenceFact() over window:length(5),
        count(1)
    )
then
    insert(new PlayerInsight("OVERCOMMIT", "Match events show repeated large elixir commits followed by tower loss, huge damage, or control loss."));
end
